# ====== Credenciales requeridas ======

# API key de Google Gemini (GRATIS). Obtenla en https://aistudio.google.com/apikey
# No requiere tarjeta de crédito. La capa gratis incluye búsqueda web (grounding).
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token de tu bot de Telegram. Lo da @BotFather al crear el bot.
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tu chat ID de Telegram (a dónde llega el reporte).
# Cómo obtenerlo: escríbele a tu bot y abre https://api.telegram.org/bot<TU_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=987654321

# ====== Opcional ======

# Secreto para proteger el endpoint del cron. Vercel lo envía como header.
# Genera uno aleatorio (ej. con: openssl rand -hex 24).
CRON_SECRET=pon-aqui-un-secreto-aleatorio-largo

# Cuántos artistas por reporte (default 6). El usuario pidió entre 5 y 8.
ARTISTS_PER_DAY=6

# Modelo de Gemini a usar (opcional). Default: gemini-2.5-flash (gratis).
# GEMINI_MODEL=gemini-2.5-flash

# Zona horaria solo para mostrar la fecha en el reporte (opcional).
# DISPLAY_TZ=America/Lima
